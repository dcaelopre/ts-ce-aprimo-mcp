# Aprimo OAuth Client Credentials (from Administration > Integration > Registrations)
APRIMO_ENVIRONMENT=your-tenant
APRIMO_CLIENT_ID=your-client-id
APRIMO_CLIENT_SECRET=your-client-secret

# Comma-separated Aprimo search-index field names to query with CONTAINS.
# Fields must exist in your tenant's search index (Aprimo Administration).
# Default: Keywords,LatestVersionOfMasterfile.FileName
# APRIMO_SEARCH_FIELDS=Keywords,Title,Description
