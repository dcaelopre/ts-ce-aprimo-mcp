# Copy this file to `.env` for local development, then fill in your values.
# Never commit `.env` — it is listed in .gitignore.
#
# This MCP server connects to Aprimo DAM (Digital Asset Management) only:
#   https://{tenant}.dam.aprimo.com/api/core
# It does not integrate with Marketing Operations or other Aprimo products.
#
# For Claude Desktop / Cursor with the Azure-hosted MCP server, prefer putting
# these values in your MCP client config instead of Azure App Settings.
# See the Claude config example at the bottom of this file.

# Aprimo tenant name (the part before .aprimo.com), e.g. ps4
APRIMO_ENVIRONMENT=your-tenant

# From Aprimo: Administration > Integration > Registrations
APRIMO_CLIENT_ID=your-client-id
APRIMO_CLIENT_SECRET=your-client-secret

# Optional: comma-separated search-index field names for record search
# APRIMO_SEARCH_FIELDS=Keywords,LatestVersionOfMasterfile.FileName

# Optional: port for local HTTP server (Azure sets PORT automatically)
# PORT=3000

